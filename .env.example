NODE_ENV=development
PORT=5000

# 운영·Preview에서는 공개 origin만 입력하고 /ko 같은 경로는 붙이지 않습니다.
APP_BASE_URL=http://localhost:5000

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public
SESSION_SECRET=replace-with-at-least-32-random-characters

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@auth.siteaiscore.com
RESEND_FROM_NAME=Site AI Score

# OpenAI 웹 답변 정밀진단
OPENAI_API_KEY=
OPENAI_WEB_SEARCH_MODEL=gpt-5.4-mini
OPENAI_EVALUATION_MODEL=gpt-5.4-mini
OPENAI_TIMEOUT_MS=120000
DEEP_DIAGNOSTIC_RUNS_PER_QUESTION=2
DEEP_DIAGNOSTIC_MAX_QUESTIONS=8

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# 현재 Replit Secrets에 등록된 기존 별칭도 향후 환경변수 로더에서 지원합니다.
Cloud_Name=
Cloud_API_Key=
Cloud_API_Secret=

SUPER_ADMIN_ID=
SUPER_ADMIN_EMAIL=sohocenter.kr@gmail.com
SUPER_ADMIN_PASSWORD_HASH=

# One-time DB migration to external Supabase
# Do not commit real values. Use Replit Secrets or local .env.migration for actual migration.
# SOURCE_DATABASE_URL can be omitted only while DATABASE_URL still points to the old Replit DB.
SOURCE_DATABASE_URL=
TARGET_DATABASE_URL=
SUPABASE_DATABASE_URL=
SUPABASE_DIRECT_URL=
