generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  AGENCY
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum AuthProvider {
  LOCAL
  GOOGLE
  SECRET_ADMIN
}

enum OrganizationType {
  CUSTOMER
  AGENCY
}

enum OrganizationMemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum SiteStatus {
  ACTIVE
  ARCHIVED
}

enum SiteFactSource {
  USER
  IMPORTED
}

enum ScanType {
  QUICK
  DEEP
  VERIFICATION
  MONITORING
}

enum ScanStatus {
  QUEUED
  RUNNING
  COMPLETED
  PARTIAL
  FAILED
  CANCELLED
}

enum FindingStatus {
  PASS
  FAIL
  BLOCKED
  NA
}

enum FindingSeverity {
  INFO
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum WorkOrderStatus {
  DRAFT
  ISSUED
  ASSIGNED
  IN_PROGRESS
  SUBMITTED
  VERIFYING
  REWORK_REQUIRED
  PASSED
  CANCELLED
}

enum WorkOrderItemStatus {
  PENDING
  IN_PROGRESS
  REWORK_REQUIRED
  REVIEW_REQUIRED
  COMPLETED
  NOT_APPLICABLE
}

enum VerificationAttemptStatus {
  QUEUED
  RUNNING
  EVALUATING
  PASSED
  REWORK_REQUIRED
  FAILED
}

enum VerificationItemResultStatus {
  PASS
  FAIL
  BLOCKED
  NOT_APPLICABLE
}

enum ScanReportCacheStatus {
  GENERATING
  READY
  FAILED
}

enum AiQuestionKind {
  BRAND
  DISCOVERY
  FEATURE
  USE_CASE
  TRUST
  COMPARISON
  CUSTOM
}

enum AiQuestionSource {
  SYSTEM
  USER
  GENERATED
}

enum AiQuestionStatus {
  ACTIVE
  ARCHIVED
}

enum AiAnswerRunStatus {
  QUEUED
  RUNNING
  COMPLETED
  PARTIAL
  FAILED
}

model AppMetadata {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_metadata")
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  name                String
  passwordHash        String?              @map("password_hash")
  role                UserRole             @default(USER)
  status              UserStatus           @default(ACTIVE)
  emailVerifiedAt     DateTime?            @map("email_verified_at")
  termsAcceptedAt     DateTime             @map("terms_accepted_at")
  privacyAcceptedAt   DateTime             @map("privacy_accepted_at")
  loginCount          Int                  @default(0) @map("login_count")
  lastLoginAt         DateTime?            @map("last_login_at")
  failedLoginAttempts Int                  @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime?            @map("locked_until")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  authAccounts        AuthAccount[]
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]
  organizationMembers OrganizationMember[]
  scansCreated                Scan[]                @relation("ScanCreator")
  workOrdersCreated           WorkOrder[]           @relation("WorkOrderCreator")
  verificationAttemptsCreated VerificationAttempt[] @relation("VerificationAttemptCreator")

  @@index([status])
  @@index([lockedUntil])
  @@map("users")
}

model AuthAccount {
  id                String       @id @default(cuid())
  userId            String       @map("user_id")
  provider          AuthProvider
  providerAccountId String       @map("provider_account_id")
  createdAt         DateTime     @default(now()) @map("created_at")
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@unique([userId, provider])
  @@index([userId])
  @@map("auth_accounts")
}

model Session {
  id               String    @id @default(cuid())
  userId           String    @map("user_id")
  sessionTokenHash String    @unique @map("session_token_hash")
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  email     String
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  verifiedAt DateTime? @map("verified_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([email])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

model Organization {
  id        String           @id @default(cuid())
  name      String
  type      OrganizationType @default(CUSTOMER)
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  members            OrganizationMember[]
  sites              Site[]
  customerWorkOrders WorkOrder[] @relation("CustomerWorkOrders")
  agencyWorkOrders   WorkOrder[] @relation("AgencyWorkOrders")

  @@index([type])
  @@map("organizations")
}

model OrganizationMember {
  id             String                 @id @default(cuid())
  organizationId String                 @map("organization_id")
  userId         String                 @map("user_id")
  role           OrganizationMemberRole @default(MEMBER)
  createdAt      DateTime               @default(now()) @map("created_at")
  organization   Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@map("organization_members")
}

model Site {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  name           String
  baseUrl        String       @map("base_url")
  finalUrl       String?      @map("final_url")
  siteType       String?      @map("site_type")
  country        String       @default("KR")
  region         String?
  primaryLocale  String       @default("ko") @map("primary_locale")
  status         SiteStatus   @default(ACTIVE)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  facts          SiteFact[]
  scans          Scan[]
  workOrders     WorkOrder[]
  aiQuestions    AiQuestion[]

  @@unique([organizationId, baseUrl])
  @@index([organizationId, status])
  @@map("sites")
}

model SiteFact {
  id            String         @id @default(cuid())
  siteId        String         @map("site_id")
  factKey       String         @map("fact_key")
  expectedValue Json           @map("expected_value")
  source        SiteFactSource @default(USER)
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  site          Site           @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, factKey])
  @@index([siteId])
  @@map("site_facts")
}

model Scan {
  id           String     @id @default(cuid())
  siteId       String     @map("site_id")
  targetUrl    String?    @map("target_url")
  type         ScanType
  status       ScanStatus @default(QUEUED)
  rulesVersion String     @map("rules_version")
  score        Float?
  grade        String?
  startedAt    DateTime?  @map("started_at")
  completedAt  DateTime?  @map("completed_at")
  errorCode    String?    @map("error_code")
  createdBy    String?    @map("created_by")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  site         Site       @relation(fields: [siteId], references: [id], onDelete: Cascade)
  creator      User?      @relation("ScanCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  pages             ScanPage[]
  findings          Finding[]
  initialWorkOrders   WorkOrder[]
  reportCaches        ScanReportCache[]
  verificationAttempt VerificationAttempt?
  aiAnswerRuns        AiAnswerRun[]
  aiAnswerSummary     AiAnswerSummary?

  @@index([siteId, createdAt])
  @@index([status, createdAt])
  @@index([createdBy])
  @@map("scans")
}

model ScanPage {
  id                 String    @id @default(cuid())
  scanId             String    @map("scan_id")
  url                String
  statusCode         Int?      @map("status_code")
  finalUrl           String?   @map("final_url")
  contentType        String?   @map("content_type")
  rawHtmlHash        String?   @map("raw_html_hash")
  renderedHtmlHash   String?   @map("rendered_html_hash")
  initialTextLength  Int?      @map("initial_text_length")
  renderedTextLength Int?      @map("rendered_text_length")
  iframeCount        Int?      @map("iframe_count")
  screenshotAssetId  String?   @map("screenshot_asset_id")
  createdAt          DateTime  @default(now()) @map("created_at")
  scan               Scan      @relation(fields: [scanId], references: [id], onDelete: Cascade)
  findings           Finding[]

  @@index([scanId])
  @@map("scan_pages")
}

model Finding {
  id            String          @id @default(cuid())
  scanId        String          @map("scan_id")
  scanPageId    String?         @map("scan_page_id")
  ruleCode      String          @map("rule_code")
  category      String
  severity      FindingSeverity
  status        FindingStatus
  title         String
  description   String
  evidenceJson  Json?           @map("evidence_json")
  recommendation String?
  scoreDelta    Float           @default(0) @map("score_delta")
  createdAt     DateTime        @default(now()) @map("created_at")
  scan          Scan            @relation(fields: [scanId], references: [id], onDelete: Cascade)
  scanPage      ScanPage?       @relation(fields: [scanPageId], references: [id], onDelete: SetNull)
  workOrderItems WorkOrderItem[]

  @@index([scanId, status])
  @@index([scanPageId])
  @@index([ruleCode])
  @@map("findings")
}

model WorkOrder {
  id                     String          @id @default(cuid())
  orderNumber            String          @map("order_number")
  siteId                 String          @map("site_id")
  initialScanId          String          @map("initial_scan_id")
  customerOrganizationId String          @map("customer_organization_id")
  agencyOrganizationId   String?         @map("agency_organization_id")
  version                Int             @default(1)
  status                 WorkOrderStatus @default(DRAFT)
  rulesVersion           String          @map("rules_version")
  scoreBefore            Float?          @map("score_before")
  gradeBefore            String?         @map("grade_before")
  expectedScoreMin       Int             @map("expected_score_min")
  expectedScoreMax       Int             @map("expected_score_max")
  issuedAt               DateTime?       @map("issued_at")
  createdBy              String?         @map("created_by")
  createdAt              DateTime        @default(now()) @map("created_at")
  updatedAt              DateTime        @updatedAt @map("updated_at")
  site                   Site            @relation(fields: [siteId], references: [id], onDelete: Cascade)
  initialScan            Scan            @relation(fields: [initialScanId], references: [id], onDelete: Cascade)
  customerOrganization   Organization    @relation("CustomerWorkOrders", fields: [customerOrganizationId], references: [id], onDelete: Cascade)
  agencyOrganization     Organization?   @relation("AgencyWorkOrders", fields: [agencyOrganizationId], references: [id], onDelete: SetNull)
  creator                User?                 @relation("WorkOrderCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  items                  WorkOrderItem[]
  verificationAttempts  VerificationAttempt[]

  @@unique([orderNumber, version])
  @@index([siteId, createdAt])
  @@index([initialScanId])
  @@index([customerOrganizationId, status])
  @@index([agencyOrganizationId])
  @@index([createdBy])
  @@map("work_orders")
}

model WorkOrderItem {
  id                     String              @id @default(cuid())
  workOrderId            String              @map("work_order_id")
  findingId              String?             @map("finding_id")
  itemCode               String              @map("item_code")
  targetUrl              String              @map("target_url")
  title                  String
  requirement            String
  developerMessage       String              @map("developer_message")
  acceptanceCriteriaJson Json                @map("acceptance_criteria_json")
  isRequired             Boolean             @default(true) @map("is_required")
  weight                 Int
  status                 WorkOrderItemStatus @default(PENDING)
  createdAt              DateTime            @default(now()) @map("created_at")
  updatedAt              DateTime            @updatedAt @map("updated_at")
  workOrder              WorkOrder                @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  finding                Finding?                 @relation(fields: [findingId], references: [id], onDelete: SetNull)
  verificationResults    VerificationItemResult[]

  @@unique([workOrderId, findingId])
  @@index([workOrderId, status])
  @@index([findingId])
  @@map("work_order_items")
}

model VerificationAttempt {
  id            String                    @id @default(cuid())
  workOrderId   String                    @map("work_order_id")
  scanId        String                    @unique @map("scan_id")
  attemptNumber Int                       @map("attempt_number")
  submittedUrl  String                    @map("submitted_url")
  status        VerificationAttemptStatus @default(QUEUED)
  scoreAfter    Float?                    @map("score_after")
  gradeAfter    String?                   @map("grade_after")
  startedAt     DateTime?                 @map("started_at")
  completedAt   DateTime?                 @map("completed_at")
  errorCode     String?                   @map("error_code")
  createdBy     String?                   @map("created_by")
  createdAt     DateTime                  @default(now()) @map("created_at")
  updatedAt     DateTime                  @updatedAt @map("updated_at")
  workOrder     WorkOrder                 @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  scan          Scan                      @relation(fields: [scanId], references: [id], onDelete: Cascade)
  creator       User?                     @relation("VerificationAttemptCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  itemResults   VerificationItemResult[]

  @@unique([workOrderId, attemptNumber])
  @@index([workOrderId, createdAt])
  @@index([status, createdAt])
  @@index([createdBy])
  @@map("verification_attempts")
}

model VerificationItemResult {
  id                    String                       @id @default(cuid())
  verificationAttemptId String                       @map("verification_attempt_id")
  workOrderItemId       String                       @map("work_order_item_id")
  status                VerificationItemResultStatus
  criteriaResultsJson   Json                         @map("criteria_results_json")
  evidenceJson          Json?                        @map("evidence_json")
  message               String?
  createdAt             DateTime                     @default(now()) @map("created_at")
  updatedAt             DateTime                     @updatedAt @map("updated_at")
  verificationAttempt   VerificationAttempt          @relation(fields: [verificationAttemptId], references: [id], onDelete: Cascade)
  workOrderItem         WorkOrderItem                @relation(fields: [workOrderItemId], references: [id], onDelete: Cascade)

  @@unique([verificationAttemptId, workOrderItemId])
  @@index([verificationAttemptId, status])
  @@index([workOrderItemId])
  @@map("verification_item_results")
}

model ScanReportCache {
  id                String                @id @default(cuid())
  scanId            String                @map("scan_id")
  reportType        String                @default("DIAGNOSTIC") @map("report_type")
  cacheKey          String                @map("cache_key")
  sourceHash        String                @map("source_hash")
  rendererVersion   String                @map("renderer_version")
  fontHash          String                @map("font_hash")
  status            ScanReportCacheStatus @default(GENERATING)
  pdfBytes          Bytes?                @map("pdf_bytes")
  pdfSha256         String?               @map("pdf_sha256")
  sizeBytes         Int?                  @map("size_bytes")
  generationToken   String?               @map("generation_token")
  lockExpiresAt     DateTime?             @map("lock_expires_at")
  generatedAt       DateTime?             @map("generated_at")
  lastAccessedAt    DateTime?             @map("last_accessed_at")
  errorMessage      String?               @map("error_message")
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")
  scan              Scan                  @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@unique([scanId, reportType])
  @@index([status, lockExpiresAt])
  @@map("scan_report_caches")
}

model AiQuestion {
  id               String           @id @default(cuid())
  siteId           String           @map("site_id")
  code             String
  kind             AiQuestionKind
  source           AiQuestionSource @default(USER)
  status           AiQuestionStatus @default(ACTIVE)
  question         String
  expectedFactKeys Json             @map("expected_fact_keys")
  isRequired       Boolean          @default(true) @map("is_required")
  sortOrder        Int              @default(0) @map("sort_order")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  site             Site             @relation(fields: [siteId], references: [id], onDelete: Cascade)
  answerRuns       AiAnswerRun[]

  @@unique([siteId, code])
  @@index([siteId, status, sortOrder])
  @@map("ai_questions")
}

model AiAnswerRun {
  id                     String            @id @default(cuid())
  scanId                 String            @map("scan_id")
  questionId             String?           @map("question_id")
  runNumber              Int               @default(1) @map("run_number")
  questionCode           String            @map("question_code")
  questionKind           AiQuestionKind    @map("question_kind")
  questionText           String            @map("question_text")
  expectedFactsSnapshot  Json              @map("expected_facts_snapshot")
  provider               String
  model                  String
  status                 AiAnswerRunStatus @default(QUEUED)
  responseId             String?           @map("response_id")
  answerText             String?           @map("answer_text")
  answerSha256           String?           @map("answer_sha256")
  brandMentioned         Boolean?          @map("brand_mentioned")
  targetDomainCited      Boolean?          @map("target_domain_cited")
  citationsJson          Json?             @map("citations_json")
  sourcesJson            Json?             @map("sources_json")
  automaticMetricsJson   Json?             @map("automatic_metrics_json")
  factualEvaluationJson  Json?             @map("factual_evaluation_json")
  consistencySignature   String?           @map("consistency_signature")
  inputTokens            Int?              @map("input_tokens")
  outputTokens           Int?              @map("output_tokens")
  errorCode              String?           @map("error_code")
  errorMessage           String?           @map("error_message")
  startedAt              DateTime?         @map("started_at")
  completedAt            DateTime?         @map("completed_at")
  createdAt              DateTime          @default(now()) @map("created_at")
  updatedAt              DateTime          @updatedAt @map("updated_at")
  scan                   Scan              @relation(fields: [scanId], references: [id], onDelete: Cascade)
  question               AiQuestion?       @relation(fields: [questionId], references: [id], onDelete: SetNull)

  @@unique([scanId, questionCode, runNumber])
  @@index([scanId, status])
  @@index([questionId, createdAt])
  @@map("ai_answer_runs")
}

model AiAnswerSummary {
  id                    String   @id @default(cuid())
  scanId                String   @unique @map("scan_id")
  provider              String
  model                 String
  methodologyVersion    String   @map("methodology_version")
  plannedQuestionCount  Int      @map("planned_question_count")
  completedQuestionCount Int     @map("completed_question_count")
  totalRunCount         Int      @map("total_run_count")
  completedRunCount     Int      @map("completed_run_count")
  partialRunCount       Int      @map("partial_run_count")
  failedRunCount        Int      @map("failed_run_count")
  answerCompletionRate  Float?   @map("answer_completion_rate")
  brandMentionRate      Float?   @map("brand_mention_rate")
  targetCitationRate    Float?   @map("target_citation_rate")
  factualAccuracy       Float?   @map("factual_accuracy")
  completeness          Float?
  consistency           Float?
  performanceScore      Float?   @map("performance_score")
  scoreCoverage         Float?   @map("score_coverage")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")
  scan                  Scan     @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@index([provider, model])
  @@map("ai_answer_summaries")
}
