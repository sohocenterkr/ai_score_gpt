{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "corepack enable && corepack prepare yarn@1.22.22 --activate && yarn run build:vercel",
  "outputDirectory": "dist/public",
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "includeFiles": "{server/assets/fonts/pretendard/**,node_modules/@sparticuz/chromium/bin/**}"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api?__apiPath=:path*"
    },
    {
      "source": "/ko",
      "destination": "/ko/index.html"
    },
    {
      "source": "/ko/guide",
      "destination": "/ko/guide/index.html"
    },
    {
      "source": "/ko/faq",
      "destination": "/ko/faq/index.html"
    },
    {
      "source": "/ko/checkout",
      "destination": "/ko/checkout/index.html"
    },
    {
      "source": "/ko/terms",
      "destination": "/ko/terms/index.html"
    },
    {
      "source": "/ko/privacy",
      "destination": "/ko/privacy/index.html"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "installCommand": "corepack enable && corepack prepare yarn@1.22.22 --activate && yarn install --non-interactive --ignore-engines --network-timeout 600000"
}
